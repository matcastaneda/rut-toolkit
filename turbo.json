{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**"]
    },
    "clean": {},
    "format": {
      "dependsOn": ["//#format"]
    },
    "//#format": {},
    "lint": {},
    "lint:types": {
      "dependsOn": ["build"]
    },
    "lint:package": {
      "dependsOn": ["build"]
    },
    "deploy": {
      "cache": false
    }
  }
}
