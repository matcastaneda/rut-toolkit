{
  "name": "rut-toolkit",
  "version": "0.0.1",
  "private": true,
  "description": "A complete toolkit for working with Chilean RUT numbers — validation, formatting, cleaning, and more.",
  "license": "MIT",
  "author": {
    "name": "Matías Castañeda",
    "url": "https://github.com/matcastaneda"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/matcastaneda/rut-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/matcastaneda/rut-toolkit/issues"
  },
  "homepage": "https://rut-toolkit.dev/",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@vitest/coverage-v8": "catalog:vitest",
    "husky": "9.1.7",
    "turbo": "2.8.20",
    "vitest": "catalog:vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1"
}
