{
  "name": "@rut-toolkit/root",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --filter=./packages/*",
    "clean": "turbo run clean",
    "clean:all": "turbo run clean && shx rm -rf node_modules",
    "format": "biome format . --write",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check . --fix --unsafe",
    "lint:dependencies": "knip --strict",
    "lint:spell": "cspell . --color",
    "lint:types": "turbo lint:types --filter=./packages/*",
    "lint:packages": "turbo lint:package --filter=./packages/*",
    "test": "turbo test --continue --filter=./packages/*",
    "test:coverage": "turbo test:coverage --filter=./packages/*",
    "typecheck": "turbo typecheck --filter=./packages/*",
    "size": "size-limit",
    "changeset": "changeset",
    "release": "changeset version",
    "pub:release": "changeset publish --access public",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.10",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@size-limit/preset-small-lib": "12.0.1",
    "@vitest/coverage-v8": "catalog:vitest",
    "cspell": "10.0.0",
    "husky": "9.1.7",
    "knip": "6.3.0",
    "publint": "0.3.18",
    "rollup-plugin-visualizer": "7.0.1",
    "shx": "0.4.0",
    "size-limit": "12.0.1",
    "turbo": "2.9.5",
    "vitest": "catalog:vitest"
  },
  "size-limit": [
    {
      "name": "📦 CORE | Main Export",
      "path": "packages/core/dist/index.mjs",
      "limit": "2.8 kB"
    },
    {
      "name": "📦 CORE | Validate",
      "path": "packages/core/dist/validate/index.mjs",
      "limit": "1.4 kB"
    },
    {
      "name": "📦 CORE | Format",
      "path": "packages/core/dist/format/index.mjs",
      "limit": "800 B"
    },
    {
      "name": "📦 CORE | Clean",
      "path": "packages/core/dist/clean/index.mjs",
      "limit": "300 B"
    },
    {
      "name": "📦 CORE | Barcode",
      "path": "packages/core/dist/barcode/index.mjs",
      "limit": "700 B"
    },
    {
      "name": "📦 CORE | Business",
      "path": "packages/core/dist/business/index.mjs",
      "limit": "1.2 kB"
    },
    {
      "name": "📦 CORE | Errors",
      "path": "packages/core/dist/errors/index.mjs",
      "limit": "1.4 kB"
    },
    {
      "name": "🧩 ZOD | Adapter (Isolated)",
      "path": "packages/zod/dist/index.mjs",
      "limit": "700 B",
      "ignore": [
        "zod",
        "@rut-toolkit/core"
      ]
    },
    {
      "name": "🧩 ZOD | Adapter + Dependencies",
      "path": "packages/zod/dist/index.mjs",
      "limit": "55 kB"
    }
  ]
}
