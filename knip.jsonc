{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
  "ignoreDependencies": ["publint"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "tags": ["-lintignore"],
  "workspaces": {
    "packages": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts!"]
    }
  }
}
