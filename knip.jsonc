{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
  "ignoreDependencies": ["publint", "@rut-toolkit/core", "zod"],
  "ignore": ["scripts/generate-size-report.js"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "tags": ["-lintignore"],
  "workspaces": {
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
