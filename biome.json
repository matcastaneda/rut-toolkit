{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentWidth": 2,
    "indentStyle": "space"
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn"
      },
      "performance": {
        "noDelete": "error"
      },
      "complexity": {
        "noBannedTypes": "off"
      },
      "style": {
        "useNodejsImportProtocol": "error",
        "noRestrictedTypes": "off",
        "useConst": "error",
        "useImportType": {
          "level": "error",
          "options": {
            "style": "separatedType"
          }
        }
      },
      "suspicious": {
        "noImplicitAnyLet": "warn",
        "noDuplicateObjectKeys": "warn",
        "noTsIgnore": "error",
        "noDebugger": "error"
      },
      "nursery": {
        "noMisusedPromises": "error",
        "noFloatingPromises": "error"
      }
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*",
      "!!**/node_modules",
      "!!**/.turbo",
      "!!**/dist",
      "!!**/build",
      "!!**/*.d.ts",
      "!!*.lock",
      "!!*.log",
      "!!.gitignore",
      "!!.npmignore",
      "!!.DS_Store",
      "!!coverage"
    ],
    "maxSize": 2097152
  }
}
