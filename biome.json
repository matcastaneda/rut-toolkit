{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentWidth": 2,
    "indentStyle": "space"
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noSvgWithoutTitle": "off",
        "useButtonType": "off",
        "useAltText": "off",
        "useKeyWithClickEvents": "off",
        "useSemanticElements": "off",
        "noLabelWithoutControl": "off"
      },
      "correctness": {
        "noNestedComponentDefinitions": "off",
        "useUniqueElementIds": "off",
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn",
        "useExhaustiveDependencies": "warn",
        "useHookAtTopLevel": "warn"
      },
      "performance": {
        "noDelete": "error"
      },
      "complexity": {
        "noBannedTypes": "off"
      },
      "style": {
        "useSelfClosingElements": "off",
        "useNodejsImportProtocol": "error",
        "useConst": "error",
        "noRestrictedTypes": "off",
        "noRestrictedGlobals": "off",
        "useImportType": {
          "level": "error",
          "options": {
            "style": "separatedType"
          }
        }
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "suspicious": {
        "noImplicitAnyLet": "warn",
        "noDuplicateObjectKeys": "warn",
        "noTsIgnore": "error",
        "noDebugger": "error",
        "noArrayIndexKey": "off"
      },
      "nursery": {
        "noMisusedPromises": "error",
        "noFloatingPromises": "error",
        "useSortedClasses": {
          "level": "warn",
          "fix": "safe",
          "options": {
            "attributes": ["classList"],
            "functions": ["clsx", "cva", "tw", "cn"]
          }
        }
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*",
      "!!**/node_modules",
      "!!**/.next",
      "!!**/.turbo",
      "!!**/dist",
      "!!**/build",
      "!!**/public",
      "!!**/*.d.ts",
      "!!*.lock",
      "!!*.log",
      "!!.gitignore",
      "!!.npmignore",
      "!!.DS_Store",
      "!!coverage"
    ],
    "maxSize": 2097152
  }
}
