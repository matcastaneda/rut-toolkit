{
  "name": "@rut-toolkit/core",
  "version": "0.1.3",
  "description": "Zero-dependency Chilean RUT/RUN utilities: validation, formatting, cleaning, and ID-card barcode parsing.",
  "author": {
    "name": "Matías Castañeda",
    "url": "https://github.com/matcastaneda"
  },
  "license": "MIT",
  "homepage": "https://rut-toolkit.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matcastaneda/rut-toolkit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/matcastaneda/rut-toolkit/issues"
  },
  "keywords": [
    "rut",
    "run",
    "chilean",
    "chile",
    "validation",
    "formatting",
    "barcode",
    "cedula",
    "id-card",
    "modulo-11",
    "check-digit",
    "digito-verificador",
    "zero-dependency",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./errors": {
      "dev-source": "./src/errors/index.ts",
      "types": "./dist/errors/index.d.mts",
      "import": "./dist/errors/index.mjs"
    },
    "./barcode": {
      "dev-source": "./src/barcode/index.ts",
      "types": "./dist/barcode/index.d.mts",
      "import": "./dist/barcode/index.mjs"
    },
    "./business": {
      "dev-source": "./src/business/index.ts",
      "types": "./dist/business/index.d.mts",
      "import": "./dist/business/index.mjs"
    },
    "./clean": {
      "dev-source": "./src/clean/index.ts",
      "types": "./dist/clean/index.d.mts",
      "import": "./dist/clean/index.mjs"
    },
    "./format": {
      "dev-source": "./src/format/index.ts",
      "types": "./dist/format/index.d.mts",
      "import": "./dist/format/index.mjs"
    },
    "./validate": {
      "dev-source": "./src/validate/index.ts",
      "types": "./dist/validate/index.d.mts",
      "import": "./dist/validate/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "barcode": [
        "./dist/barcode/index.d.mts"
      ],
      "business": [
        "./dist/business/index.d.mts"
      ],
      "clean": [
        "./dist/clean/index.d.mts"
      ],
      "errors": [
        "./dist/errors/index.d.mts"
      ],
      "format": [
        "./dist/format/index.d.mts"
      ],
      "validate": [
        "./dist/validate/index.d.mts"
      ]
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint:package": "publint run --strict",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@rut-toolkit/tsconfig": "workspace:*",
    "@rut-toolkit/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest"
  },
  "engines": {
    "node": ">=18"
  }
}
