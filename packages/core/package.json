{
  "name": "@rut-toolkit/core",
  "version": "0.1.0",
  "description": "Enterprise-grade, zero-dependency toolkit for Chilean RUT/RUN validation, formatting, and ID barcode parsing.",
  "author": {
    "name": "Matías Castañeda",
    "url": "https://github.com/matcastaneda"
  },
  "license": "MIT",
  "homepage": "https://rut-toolkit.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matcastaneda/rut-toolkit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/matcastaneda/rut-toolkit/issues"
  },
  "keywords": [
    "rut",
    "run",
    "chilean",
    "chile",
    "validation",
    "formatting",
    "modulo-11",
    "digito-verificador",
    "toolkit",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ]
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint:package": "publint run --strict",
    "lint:types": "attw --pack .",
    "typecheck": "tsc --project tsconfig.json"
  },
  "devDependencies": {
    "@rut-toolkit/tsconfig": "workspace:*",
    "@rut-toolkit/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
