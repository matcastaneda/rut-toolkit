{
  "name": "@rut-toolkit/zod",
  "version": "0.1.1",
  "description": "Zod v4 schemas for Chilean RUT/RUN validation with automatic formatting, i18n error messages, and typed custom issues.",
  "author": {
    "name": "Matías Castañeda",
    "url": "https://github.com/matcastaneda"
  },
  "license": "MIT",
  "homepage": "https://rut-toolkit.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matcastaneda/rut-toolkit.git",
    "directory": "packages/zod"
  },
  "bugs": {
    "url": "https://github.com/matcastaneda/rut-toolkit/issues"
  },
  "keywords": [
    "zod",
    "rut",
    "run",
    "chilean",
    "chile",
    "schema",
    "validation",
    "validator",
    "parse",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint:package": "publint run --strict",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@rut-toolkit/core": "workspace:*",
    "@rut-toolkit/tsconfig": "workspace:*",
    "@rut-toolkit/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@rut-toolkit/core": ">=0.1.0",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
