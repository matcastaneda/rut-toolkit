{
  "name": "@rut-toolkit/react",
  "version": "0.1.0",
  "description": "The complete React toolkit for Chilean RUT/RUN. Includes a specialized Input component, Context provider for global state, and hooks for real-time formatting and validation.",
  "author": {
    "name": "Matías Castañeda",
    "url": "https://github.com/matcastaneda"
  },
  "license": "MIT",
  "homepage": "https://rut-toolkit.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matcastaneda/rut-toolkit.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/matcastaneda/rut-toolkit/issues"
  },
  "keywords": [
    "react",
    "hooks",
    "rut",
    "run",
    "chile",
    "chilean",
    "validation",
    "input",
    "format",
    "i18n",
    "typescript",
    "components",
    "context",
    "parse",
    "validator"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint:package": "publint run --strict",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "size": "size-limit",
    "size:json": "size-limit --json > .size-report.json"
  },
  "dependencies": {
    "@rut-toolkit/core": "workspace:*"
  },
  "devDependencies": {
    "@rut-toolkit/tsconfig": "workspace:*",
    "@rut-toolkit/tsdown": "workspace:*",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitest/ui": "4.1.4",
    "jsdom": "29.0.2",
    "react": "catalog:react",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
